{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch:css (sass)",
      "type": "shell",
      "command": "npm run watch:css",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "sass",
          "pattern": [
            {
              "regexp": "^(.*)$",
              "message": 1
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Sass is watching for changes\\.",
            "endsPattern": "Sass is watching for changes\\."
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}


